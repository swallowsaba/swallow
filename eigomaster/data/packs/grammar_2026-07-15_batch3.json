{"collection": "grammar", "type": "array", "data": [{"id": "gxf_1", "title": "as if / as though", "ja": "「まるで〜のように」= as if + 仮定法。", "level": "B2", "examples": [{"en": "He talks as if he knew everything.", "ja": "「まるで〜のように」= as if + 仮定法。"}], "blank": {"before": "He talks as if he ", "after": " everything.", "options": ["knew", "knows", "know", "known"], "answer": "knew", "ja": "「まるで〜のように」= as if + 仮定法。", "explain": {"answer": "knew", "why": "現実に反する→仮定法過去。", "opts": {}}}}, {"id": "gxf_2", "title": "It's (about/high) time", "ja": "「そろそろ〜する時間」= It's time + 過去形。", "level": "C1", "examples": [{"en": "It's high time we left.", "ja": "「そろそろ〜する時間」= It's time + 過去形。"}], "blank": {"before": "It's high time we ", "after": ".", "options": ["left", "leave", "will leave", "leaving"], "answer": "left", "ja": "「そろそろ〜する時間」= It's time + 過去形。", "explain": {"answer": "left", "why": "It's time + 仮定法過去。", "opts": {}}}}, {"id": "gxf_3", "title": "would sooner / would just as soon", "ja": "「むしろ〜したい」= would sooner + 原形。", "level": "C1", "examples": [{"en": "I'd sooner quit than apologize.", "ja": "「むしろ〜したい」= would sooner + 原形。"}], "blank": {"before": "I'd sooner ", "after": " than apologize.", "options": ["quit", "to quit", "quitting", "quits"], "answer": "quit", "ja": "「むしろ〜したい」= would sooner + 原形。", "explain": {"answer": "quit", "why": "would sooner + 原形。", "opts": {}}}}, {"id": "gxf_4", "title": "not so much A as B", "ja": "「AというよりむしろB」。", "level": "C1", "examples": [{"en": "He's not so much shy as cautious.", "ja": "「AというよりむしろB」。"}], "blank": {"before": "He's not so much shy ", "after": " cautious.", "options": ["as", "but", "than", "so"], "answer": "as", "ja": "「AというよりむしろB」。", "explain": {"answer": "as", "why": "not so much A as B。", "opts": {}}}}, {"id": "gxf_5", "title": "no sooner ... than", "ja": "「〜するやいなや」= No sooner + 倒置 + than。", "level": "C1", "examples": [{"en": "No sooner had he arrived than it started raining.", "ja": "「〜するやいなや」= No sooner + 倒置 + than。"}], "blank": {"before":