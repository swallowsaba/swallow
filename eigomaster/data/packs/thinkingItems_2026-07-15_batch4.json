{"collection": "thinkingItems", "type": "array", "data": [{"level": "B1", "ja": "", "text": "「よろしくお願いします(依頼)」を英語らしく言うと？", "choices": ["Thanks in advance.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "依頼の締め。"}, {"level": "B1", "ja": "", "text": "「お世話になっております」を英語らしく言うと？", "choices": ["Thank you for your continued support.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "ビジネスメール定番。※直訳不可の代表。"}, {"level": "B1", "ja": "", "text": "「いただきます」を英語らしく言うと？", "choices": ["Let's eat! / Thanks for the food.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "対応する定型句が英語にない。"}, {"level": "B1", "ja": "", "text": "「お先にどうぞ」を英語らしく言うと？", "choices": ["After you.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "譲る時の定番。"}, {"level": "B2", "ja": "", "text": "「微妙な空気になった」を英語らしく言うと？", "choices": ["The mood got awkward.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "気まずさ=awkward。"}, {"level": "B2", "ja": "", "text": "「グダグダになった」を英語らしく言うと？", "choices": ["It fell apart. / It fizzled out.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "失速・崩壊のニュアンス。"}, {"level": "B2", "ja": "", "text": "「なあなあで済ませる」を英語らしく言うと？", "choices": ["sweep it under the rug", "直訳英語", "不自然な英語", "逐語訳"], "explain": "うやむやにする。"}, {"level": "B2", "ja": "", "text": "「その場しのぎ」を英語らしく言うと？", "choices": ["a quick fix / a band-aid solution", "直訳英語", "不自然な英語", "逐語訳"], "explain": "応急処置的対応。"}, {"level": "B2", "ja": "", "text": "「見て見ぬふり」を英語らしく言うと？", "choices": ["turn a blind eye", "直訳英語", "不自然な英語", "逐語訳"], "explain": "気づいても無視。"}, {"level": "B2", "ja": "", "text": "「けなげ」を英語らしく言うと？", "choices": ["admirably resilient", "直訳英語", "不自然な英語", "逐語訳"], "explain": "健気に対応する1語はない。"}, {"level": "B2", "ja": "", "text": "「わがまま」を英語らしく言うと？", "choices": ["selfish / spoiled", "直訳英語", "不自然な英語", "逐語訳"], "explain": "文脈で使い分け。"}, {"level": "B2", "ja": "", "text": "「甘えん坊」を英語らしく言うと？", "choices": ["clingy / needy", "直訳英語", "不自然な英語", "逐語訳"], "explain": "ペットや子供に。"}, {"level": "C1", "ja": "", "text": "「よそよそしい」を英語らしく言うと？", "choices": ["distant / standoffish", "直訳英語", "不自然な英語", "逐語訳"], "explain": "心理的距離。"}, {"level": "C1", "ja": "", "text": "「馴れ馴れしい」を英語らしく言うと？", "choices": ["overly familiar", "直訳英語", "不自然な英語", "逐語訳"], "explain": "距離感の侵害。"}, {"level": "C1", "ja": "", "text": "「あざとい」を英語らしく言うと？", "choices": ["calculatedly charming", "直訳英語", "不自然な英語", "逐語訳"], "explain": "計算された可愛さ。"}, {"level": "C1", "ja": "", "text": "「いじらしい」を英語らしく言うと？", "choices": ["endearingly earnest", "直訳英語", "不自然な英語", "逐語訳"], "explain": "健気で愛らしい。"}, {"level": "C1", "ja": "", "text": "「潔い」を英語らしく言うと？", "choices": ["graceful in defeat / owning it", "直訳英語", "不自然な英語", "逐語訳"], "explain": "負けを認める美学。"}, {"level": "C1", "ja": "", "text": "「未練がましい」を英語らしく言うと？", "choices": ["unable to let go", "直訳英語", "不自然な英語", "逐語訳"], "explain": "執着が残る様。"}, {"level": "C1", "ja": "", "text": "「往生際が悪い」を英語らしく言うと？", "choices": ["a sore loser / refusing to accept defeat", "直訳英語", "不自然な英語", "逐語訳"], "explain": "負けを認めない。"}, {"level": "C1", "ja": "", "text": "「腹八分目」を英語らしく言うと？", "choices": ["eat until you're 80 percent full", "直訳英語", "不自然な英語", "逐語訳"], "explain": "日本的節制の知恵。"}]}