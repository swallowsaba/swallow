{"collection": "thinkingItems", "type": "array", "data": [{"level": "B1", "ja": "", "text": "「がんばって」を英語らしく言うと？", "choices": ["Good luck! / You got this!", "直訳英語", "不自然な英語", "逐語訳"], "explain": "応援。"}, {"level": "B1", "ja": "", "text": "「気にしないで」を英語らしく言うと？", "choices": ["Don't sweat it.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "気にするな。"}, {"level": "B2", "ja": "", "text": "「そこは譲れない」を英語らしく言うと？", "choices": ["That's a dealbreaker for me.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "譲歩不可点。"}, {"level": "B2", "ja": "", "text": "「言った者勝ち」を英語らしく言うと？", "choices": ["First to speak up wins.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "早い者勝ち。"}, {"level": "B2", "ja": "", "text": "「言わぬが花」を英語らしく言うと？", "choices": ["Some things are better left unsaid.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "不言の美徳。"}, {"level": "B2", "ja": "", "text": "「損して得取れ」を英語らしく言うと？", "choices": ["Take a short-term loss for a long-term gain.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "戦略的譲歩。"}, {"level": "B2", "ja": "", "text": "「本音を言うと」を英語らしく言うと？", "choices": ["To be honest with you...", "直訳英語", "不自然な英語", "逐語訳"], "explain": "本音の前置き。"}, {"level": "C1", "ja": "", "text": "「潮時」を英語らしく言うと？", "choices": ["time to move on", "直訳英語", "不自然な英語", "逐語訳"], "explain": "切り上げ時。"}, {"level": "C1", "ja": "", "text": "「地道な努力」を英語らしく言うと？", "choices": ["steady, consistent effort", "直訳英語", "不自然な英語", "逐語訳"], "explain": "こつこつ。"}, {"level": "C1", "ja": "", "text": "「持ちつ持たれつ」を英語らしく言うと？", "choices": ["give and take", "直訳英語", "不自然な英語", "逐語訳"], "explain": "相互扶助。"}, {"level": "C1", "ja": "", "text": "「頭を切り替える」を英語らしく言うと？", "choices": ["reset one's mindset", "直訳英語", "不自然な英語", "逐語訳"], "explain": "気持ちの切替。"}, {"level": "C1", "ja": "", "text": "「腹落ちする」を英語らしく言うと？", "choices": ["really click / make sense", "直訳英語", "不自然な英語", "逐語訳"], "explain": "納得。"}, {"level": "C1", "ja": "", "text": "「気が置けない」を英語らしく言うと？", "choices": ["easy to be around", "直訳英語", "不自然な英語", "逐語訳"], "explain": "気楽な関係。"}, {"level": "C1", "ja": "", "text": "「腰が重い」を英語らしく言うと？", "choices": ["slow to get movin