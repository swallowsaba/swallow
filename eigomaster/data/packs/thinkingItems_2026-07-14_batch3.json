{"collection": "thinkingItems", "type": "array", "data": [{"level": "B1", "ja": "", "text": "「ぼちぼちです」を英語らしく言うと？", "choices": ["Not bad. / Getting by.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "近況の曖昧な返し。"}, {"level": "B1", "ja": "", "text": "「お先に失礼します」を英語らしく言うと？", "choices": ["I'll head out now.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "退勤時の定番。"}, {"level": "B1", "ja": "", "text": "「お疲れ様でした」を英語らしく言うと？", "choices": ["Good work today.", "直訳英語", "不自然な英語", "逐語訳"], "explain": "労いの挨拶。"}, {"level": "B2", "ja": "", "text": "「話を蒸し返す」を英語らしく言うと？", "choices": ["bring it up again", "直訳英語", "不自然な英語", "逐語訳"], "explain": "終わった話を再び持ち出す。"}, {"level": "B2", "ja": "", "text": "「上から目線」を英語らしく言うと？", "choices": ["condescending / patronizing", "直訳英語", "不自然な英語", "逐語訳"], "explain": "見下した態度。"}, {"level": "B2", "ja": "", "text": "「空回りしている」を英語らしく言うと？", "choices": ["spinning one's wheels", "直訳英語", "不自然な英語", "逐語訳"], "explain": "努力が成果に結びつかない。"}, {"level": "B2", "ja": "", "text": "「手のひら返し」を英語らしく言うと？", "choices": ["a complete about-face", "直訳英語", "不自然な英語", "逐語訳"], "explain": "突然態度を変えること。"}, {"level": "B2", "ja": "", "text": "「ツッコミどころ満載」を英語らしく言うと？", "choices": ["full of holes", "直訳英語", "不自然な英語", "逐語訳"], "explain": "矛盾だらけ。"}, {"level": "C1", "ja": "", "text": "「角が立つ」を英語らしく言うと？", "choices": ["rub people the wrong way", "直訳英語", "不自然な英語", "逐語訳"], "explain": "人の感情を逆なでする。"}, {"level": "C1", "ja": "", "text": "「一石を投じる」を英語らしく言うと？", "choices": ["spark a debate", "直訳英語", "不自然な英語", "逐語訳"], "explain": "議論のきっかけを作る。"}]}