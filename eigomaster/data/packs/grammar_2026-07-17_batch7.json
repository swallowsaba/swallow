{"collection": "grammar", "type": "array", "data": [{"id": "gxl_1", "title": "would rather + subject + past", "ja": "「〜してもらいたい」他人の希望。", "level": "C1", "examples": [{"en": "I'd rather you didn't that.", "ja": "「〜してもらいたい」他人の希望。"}], "blank": {"before": "I'd rather you ", "after": " that.", "options": ["didn't", "don't", "not to", "won't"], "answer": "didn't", "ja": "「〜してもらいたい」他人の希望。", "explain": {"answer": "didn't", "why": "would rather + 主語 + 過去形。", "opts": {}}}}, {"id": "gxl_2", "title": "it's time + subject + past", "ja": "「〜する頃合い」仮定法過去。", "level": "B2", "examples": [{"en": "It's time you went to bed.", "ja": "「〜する頃合い」仮定法過去。"}], "blank": {"before": "It's time you ", "after": " to bed.", "options": ["went", "go", "should go", "are going"], "answer": "went", "ja": "「〜する頃合い」仮定法過去。", "explain": {"answer": "went", "why": "It's time + 主語 + 過去形。", "opts": {}}}}, {"id": "gxl_3", "title": "but that", "ja": "「〜がなかったら」formal。", "level": "C1", "examples": [{"en": "She would have failed but for your help.", "ja": "「〜がなかったら」formal。"}], "blank": {"before": "She would have failed but ", "after": " your help.", "options": ["for", "that", "if", "of"], "answer": "for", "ja": "「〜がなかったら」formal。", "explain": {"answer": "for", "why": "but for = without。", "opts": {}}}}, {"id": "gxl_4", "title": "were subject to", "ja": "「もし〜する事があれば」formal 仮定。", "level": "C1", "examples": [{"en": "Were he to arrive late, we'd start without him.", "ja": "「もし〜する事があれば」formal 仮定。"}], "blank": {"before": "", "after": " he to arrive late, we'd start without him.", "options": ["Were", "Was", "Should", "If"], "answer": "Were", "ja": "「もし〜する事があれば」formal 仮定。", "explain": {"answer": "Were", "why": "Were + 主語 + to + 原形(倒置仮定法)。", "opts": {}}}}, {"id": "gxl_5", "title": "all one has to do", "ja": "「〜さえすればよい」。", "level": "B2", "examples": [{"en": "All you have to do is ask.", "ja": "「〜さえすればよい」。"}], "blank": {"before": "All you have to do ", "after": " ask.", "options": ["is", "to", "for", "of"], "answer": "is", "ja": "「〜さえすればよい」。", "explain": {"answer": "is", "why": "All 主語 have to do is + 原形。", "opts": {}}}}, {"id": "gxl_6", "title": "would sooner ... than", "ja": "「むしろ〜したい」= would rather。", "level": "C1", "examples": [{"en": "I'd sooner walk than take a taxi.", "ja": "「むしろ〜したい」= would rather。"}], "blank": {"before": "I'd sooner walk ", "after": " take a taxi.", "options": ["than", "then", "to", "for"], "answer": "than", "ja": "「むしろ〜したい」= would rather。", "explain": {"answer": "than", "why": "would sooner + 原形 + than。", "opts": {}}}}, {"id": "gxl_7", "title": "far from", "ja": "「〜どころか」。", "level": "B2", "examples": [{"en": "Far from being angry, she was actually pleased.", "ja": "「〜どころか」。"}], "blank": {"before": "Far from being angry, she was ", "after": " pleased.", "options": ["actually", "angry", "not", "hardly"], "answer": "actually", "ja": "「〜どころか」。", "explain": {"answer": "actually", "why": "Far from + Ving/形容詞 = むしろ逆。", "opts": {}}}}, {"id": "gxl_8", "title": "no less than", "ja": "「〜もの数の」= 強調。", "level": "B2", "examples": [{"en": "There were no less than 100 people.", "ja": "「〜もの数の」= 強調。"}], "blank": {"before": "There were no less ", "after": " 100 people.", "options": ["than", "as", "that", "then"], "answer": "than", "ja": "「〜もの数の」= 強調。", "explain": {"answer": "than", "why": "no less than = as many as。", "opts": {}}}}, {"id": "gxl_9", "title": "nothing but", "ja": "「〜以外の何物でもない」。", "level": "B2", "examples": [{"en": "This is nothing but a scam.", "ja": "「〜以外の何物でもない」。"}], "blank": {"before": "This is nothing ", "after": " a scam.", "options": ["but", "that", "than", "except"], "answer": "but", "ja": "「〜以外の何物でもない」。", "explain": {"answer": "but", "why": "nothing but = 単なる〜。", "opts": {}}}}, {"id": "gxl_10", "title": "anything but", "ja": "「〜どころではない」。", "level": "B2", "examples": [{"en": "She's anything but shy.", "ja": "「〜どころではない」。"}], "blank": {"before": "She's anything ", "after": " shy.", "options": ["but", "that", "than", "except"], "answer": "but", "ja": "「〜どころではない」。", "explain": {"answer": "but", "why": "anything but = 決して〜ない。", "opts": {}}}}]}