{"collection": "intonationItems", "type": "array", "data": [{"level": "B1", "text": "Would you like some more?", "q": "勧めの調子は？", "choices": ["上げる↗（丁寧な勧め）", "下げる↘", "平坦", "上下"], "explain": "勧めのYes/No疑問は上げ↗。"}, {"level": "B1", "text": "Shall we begin?", "q": "提案の調子は？", "choices": ["上げる↗", "下げる↘", "平坦", "上下"], "explain": "提案の疑問は上げ↗。"}, {"level": "B1", "text": "Why don't we take a break?", "q": "提案の調子は？", "choices": ["下げる↘（WH形の提案）", "上げる↗", "平坦", "上下"], "explain": "Why don't we は形はWHでも提案。下げ↘。"}, {"level": "B2", "text": "I suppose so.", "q": "消極的同意の調子は？", "choices": ["下げる↘やや弱く", "上げる↗", "平坦強く", "上下"], "explain": "消極的同意は弱い下げ↘。"}, {"level": "B2", "text": "If you say so.", "q": "不承不承の調子は？", "choices": ["下げる↘", "上げる↗", "平坦", "上下"], "explain": "不承不承の受諾は下げ↘。"}, {"level": "B2", "text": "Whatever you think is best.", "q": "委任の調子は？", "choices": ["下げる↘", "上げる↗", "平坦", "上下"], "explain": "委任の表現は下げ↘。"}, {"level": "B2", "text": "I guess we could try.", "q": "消極的提案の調子は？", "choices": ["下げる↘弱く", "上げる↗", "平坦", "上下"], "explain": "確信のない提案は弱い下げ。"}, {"level": "C1", "text": "Far be it from me to criticize, but...", "q": "皮肉的前置きの調子は？", "choices": ["前半平坦→but前で保留の上げ", "全体強い下げ", "全体上げ", "強弱なし"], "explain": "皮肉的前置きはbut前に含みを残す。"}, {"level": "C1", "text": "With the greatest respect...", "q": "強い異論の前置きの調子は？", "choices": ["丁寧だが下げ↘で強い異論を予告", "上げ↗で賞賛", "平坦で無関心", "歌うように"], "explain": "英式では強い異論の前触れ。"}, {"level": "C1", "text": "That's certainly one approach.", "q": "婉曲批判の調子は？", "choices": ["certainly を強く+下げ↘", "approach を上げ↗", "全体上げ", "全体弱く"], "explain": "『一つのやり方ではある』=婉曲な批判。"}]}