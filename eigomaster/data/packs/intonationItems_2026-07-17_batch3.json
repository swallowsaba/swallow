{"collection": "intonationItems", "type": "array", "data": [{"level": "B1", "text": "Excuse me?", "q": "失礼？(何と？)の読み方は？", "choices": ["me↗で聞き返し", "下げ↘で謝罪", "平坦", "叫ぶ"], "explain": "me↗で「もう一度」の意。"}, {"level": "B1", "text": "Pardon?", "q": "え？何て？の読み方は？", "choices": ["Pardon↗で聞き返し", "下げ↘は不自然", "平坦", "叫ぶ"], "explain": "上げ調で聞き返し。"}, {"level": "B2", "text": "Are you sure? Are you SURE?", "q": "本当？本当に？の読み方は？", "choices": ["最初は確認↗、次はSURE強調で疑い", "両方同じ", "下げ→上げ", "無感情"], "explain": "繰り返し時にSURE強調で疑念。"}, {"level": "B2", "text": "You WOULD say that.", "q": "君ならそう言うだろうね。の読み方は？", "choices": ["WOULDを強く長く=皮肉", "短く言うと同意", "中立の予測", "質問"], "explain": "WOULD強調で皮肉・予測の含意。"}, {"level": "B2", "text": "Oh, THAT one.", "q": "ああ、そっちね。の読み方は？", "choices": ["THATを強く=区別", "THIS強調は不可", "平坦", "質問調"], "explain": "区別のTHAT強勢。"}, {"level": "B2", "text": "Well, WELL, well.", "q": "おやおや。の読み方は？", "choices": ["中央のWELLを高く=驚き", "全て同じ", "早口", "低く"], "explain": "3回のWELLで含みのある驚き。"}, {"level": "C1", "text": "I'm not saying you're WRONG...", "q": "君が間違ってると言ってるわけじゃないが…の読み方は？", "choices": ["WRONGを高く+間で否定の含意", "下げ切り", "早口", "無音"], "explain": "WRONG強調+ポーズで婉曲否定。"}, {"level": "C1", "text": "No, no, NO.", "q": "違う違う違う。の読み方は？", "choices": ["3回目のNOを最も強く", "1回目強調", "早口", "平坦"], "explain": "3回目に決定的な否定。"}, {"level": "C1", "text": "Yes, but...", "q": "はい、しかし…の読み方は？", "choices": ["butの後の間で反論の合図", "即答", "早口", "無音"], "explain": "間で反論を予告。"}, {"level": "C1", "text": "Fine.", "q": "結構(不機嫌)。の読み方は？", "choices": ["下げ切りで不機嫌", "上げると了解", "平坦", "叫ぶ"], "explain": "下げ切りは怒りの含意。"}, {"level": "C1", "text": "Interesting.", "q": "興味深い(否定的)。の読み方は？", "choices": ["長く下げると懐疑", "短く上げると純粋な興味", "平坦は中立", "叫ぶ"], "explain": "長さで意味が変わる典型例。"}, {"level": "C1", "text": "We'll SEE.", "q": "様子見ようか。の読み方は？", "choices": ["SEEを長く下げる=疑い", "短く上げると同意", "中立", "上げ切り"], "explain": "SEE長下げは「実現しないだろう」。"}]}